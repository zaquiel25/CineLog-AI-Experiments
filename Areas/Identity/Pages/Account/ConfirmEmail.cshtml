@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm Email";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="text-center mb-4">
            <img src="~/images/logo-gold.svg" alt="FrameRoute" height="80" class="mb-3">
        </div>

        @if (Model.StatusMessage == null)
        {
            <div class="text-center">
                <h3>Confirming your email...</h3>
            </div>
        }
        else if (Model.StatusMessage.StartsWith("Error"))
        {
            <div class="alert alert-danger text-center" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@Model.StatusMessage
            </div>
            <div class="text-center mt-3">
                <a asp-page="./Login" class="text-decoration-none">Back to Login</a>
            </div>
        }
        else
        {
            <div class="alert alert-success text-center" role="alert">
                <i class="fas fa-check-circle me-2"></i>@Model.StatusMessage
            </div>
            <div class="text-center mt-3">
                <a asp-page="./Login" class="btn btn-primary">Sign In</a>
            </div>
        }
    </div>
</div>
