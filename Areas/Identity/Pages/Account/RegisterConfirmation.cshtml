@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0" style="background-color: var(--cinelog-card-bg, #222244);">
            <div class="card-body text-center p-4 p-md-5">
                <img src="~/images/logo-gold.svg" alt="FrameRoute" height="60" class="mb-4">
                <h3 class="mb-3">Check Your Email</h3>
                <p class="text-muted mb-1">We sent a confirmation link to</p>
                <p class="fw-bold mb-4" style="color: var(--cinelog-gold, #f4d03f);">@Model.Email</p>

                <div class="alert alert-secondary py-3 mb-4" role="alert">
                    <i class="fas fa-envelope me-2"></i>
                    Click the link in the email to activate your account.
                </div>

                <p class="text-muted small mb-2">Didn't receive the email? Check your spam folder or</p>
                <a asp-page="./ResendEmailConfirmation" class="text-decoration-none d-block mb-3">Resend confirmation email</a>
                <a asp-page="./Login" class="text-decoration-none text-muted small">Back to Login</a>
            </div>
        </div>
    </div>
</div>
