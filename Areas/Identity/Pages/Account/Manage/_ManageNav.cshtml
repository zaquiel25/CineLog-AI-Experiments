@*
    FEATURE: Account Management Navigation - Identity Sidebar

    This navigation component provides access to essential account management features
    with a simplified, user-focused interface.

    DESIGN DECISION:
    - Shows only 3 essential pages: Profile, Password, External Logins
    - Email, Two-Factor Authentication, and Personal Data are intentionally hidden
    - Rationale: Personal movie logging app doesn't require enterprise-level security features
    - Hidden pages remain accessible via direct URL if needed (commented out for easy reactivation)

    IMPLEMENTATION:
    - Font Awesome icons for visual clarity
    - Active page highlighting via ManageNavPages helper
    - Conditional display of External Logins based on configured authentication schemes
*@
@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="nav nav-pills flex-column manage-nav">
    <li class="nav-item">
        <a class="nav-link manage-nav-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
            <i class="fa-solid fa-user-circle"></i>
            <span class="manage-nav-text">Profile</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link manage-nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
            <i class="fa-solid fa-lock-keyhole"></i>
            <span class="manage-nav-text">Password</span>
        </a>
    </li>
    @if (hasExternalLogins)
    {
        <li id="external-logins" class="nav-item">
            <a id="external-login" class="nav-link manage-nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">
                <i class="fa-solid fa-right-left"></i>
                <span class="manage-nav-text">External logins</span>
            </a>
        </li>
    }
    @* HIDDEN: Email, 2FA, and Personal Data pages use default Bootstrap styling
    <li class="nav-item">
        <a class="nav-link manage-nav-link @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">
            <i class="fa-solid fa-envelope-open-text"></i>
            <span class="manage-nav-text">Email</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link manage-nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
            <i class="fa-solid fa-shield-halved"></i>
            <span class="manage-nav-text">Two-factor authentication</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link manage-nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">
            <i class="fa-solid fa-database"></i>
            <span class="manage-nav-text">Personal data</span>
        </a>
    </li>
    *@
</ul>
