@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="text-center mb-4">
            <img src="~/images/logo-gold.svg" alt="FrameRoute" height="80" class="mb-3">
            <h3 class="mb-1">Check Your Email</h3>
            <p class="text-muted">If an account exists with that email, we've sent a password reset link.</p>
        </div>

        <div class="alert alert-secondary text-center" role="alert">
            <i class="fas fa-envelope me-2"></i>
            Check your inbox and click the reset link.
        </div>

        <div class="text-center mt-3">
            <a asp-page="./Login" class="text-decoration-none">Back to Login</a>
        </div>
    </div>
</div>
