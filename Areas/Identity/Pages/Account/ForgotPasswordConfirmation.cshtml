@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0" style="background-color: var(--cinelog-card-bg, #222244);">
            <div class="card-body text-center p-4 p-md-5">
                <img src="~/images/logo-gold.svg" alt="FrameRoute" height="60" class="mb-4">
                <h3 class="mb-3">Check Your Email</h3>
                <p class="text-muted mb-4">If an account exists with that email, we've sent a password reset link.</p>

                <div class="alert alert-secondary py-3 mb-4" role="alert">
                    <i class="fas fa-envelope me-2"></i>
                    Check your inbox and click the reset link.
                </div>

                <a asp-page="./Login" class="text-decoration-none text-muted small">Back to Login</a>
            </div>
        </div>
    </div>
</div>
