@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="text-center mb-4">
            <img src="~/images/logo-gold.svg" alt="FrameRoute" height="80" class="mb-3">
            <h3 class="mb-1">Password Reset</h3>
        </div>

        <div class="alert alert-success text-center" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            Your password has been reset successfully.
        </div>

        <div class="text-center mt-3">
            <a asp-page="./Login" class="btn btn-primary">Sign In</a>
        </div>
    </div>
</div>
