{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:{AZURE_SQL_SERVER},1433;Database={AZURE_SQL_DATABASE};User ID={AZURE_SQL_USER};Password={DatabasePassword};Encrypt=True;TrustServerCertificate=False;Connection Timeout=60"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "VaultUri": "https://[YOUR-KEYVAULT].vault.azure.net/"
  },
  "TMDB": {
    "AccessToken": "{TMDB--AccessToken}"
  }
}