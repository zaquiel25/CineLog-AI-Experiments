@model Ezequiel_Movies.Models.TmdbApi.TmdbMovieDetails

@{
    ViewData["Title"] = $"Preview: {Model.Title}";
    var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/w500";
    var isAlreadyLogged = (bool)(ViewData["IsAlreadyLogged"] ?? false);
    var isInWishlist = (bool)(ViewData["IsInWishlist"] ?? false);
    var isInBlacklist = (bool)(ViewData["IsInBlacklist"] ?? false);
}

<div>
    @* --- Header Section --- *@
    <div class="d-flex align-items-center mb-3">
        <h1 class="display-4 mb-0">@Model.Title</h1>
        @if (isAlreadyLogged)
        {
            <span class="badge bg-success ms-3" style="font-size: 1rem;">In Your Log</span>
        }
    </div>
    <p class="text-muted">@Model.Tagline</p>
    <hr />

    @* --- Main Content Row --- *@
    <div class="row">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.PosterPath))
            {
                <img src="@(tmdbImageBaseUrl + Model.PosterPath)" class="img-fluid rounded shadow-sm" alt="@Model.Title Poster">
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center bg-light rounded shadow-sm" style="width: 100%; height: 450px; border: 1px dashed #ccc;">
                    <span class="text-muted">No Poster Available</span>
                </div>
            }
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Director</dt>
                <dd class="col-sm-9">@Model.GetDirector()</dd>

                <dt class="col-sm-3">Released</dt>
                <dd class="col-sm-9">@Model.ReleaseDate</dd>

                <dt class="col-sm-3">Genres</dt>
                <dd class="col-sm-9">@(Model.Genres != null && Model.Genres.Any() ? string.Join(", ", Model.Genres.Select(g => g.Name)) : "N/A")</dd>

                <dt class="col-sm-3">Rating</dt>
                <dd class="col-sm-9"><i class="bi bi-star-fill" style="color: #ffc107;"></i> @Model.VoteAverage.ToString("0.0") / 10</dd>
            </dl>

            <h5 class="mt-4">Overview</h5>
            <p>@Model.Overview</p>

            @* --- Cast Section --- *@
            @{
                var cast = Model.Credits?.Cast;
            }
            @if (cast != null && cast.Any())
            {
                <h5 class="mt-4">Starring</h5>
                <div class="d-flex">
                    @foreach (var actor in cast.Take(4))
                    {
                        <div class="text-center me-3">
                            @if(!string.IsNullOrEmpty(actor.ProfilePath))
                            {
                                <img src="@(tmdbImageBaseUrl.Replace("w500", "w185") + actor.ProfilePath)"
                                     class="rounded-circle"
                                     style="width: 60px; height: 60px; object-fit: cover;"
                                     title="@actor.Name"
                                     alt="@actor.Name profile picture">
                            }
                            <p class="mb-0" style="font-size: 0.8rem;">@actor.Name</p>
                        </div>
                    }
                </div>
            }

            @* --- "Where to Watch" Section --- *@
            @{
                var streamingProviders = ViewData["StreamingProviders"] as List<Ezequiel_Movies.Models.TmdbApi.ProviderInfo>;
            }
            @if (streamingProviders != null && streamingProviders.Any())
            {
                <h5 class="mt-4">Where to Watch</h5>
                <div class="d-flex flex-wrap">
                    @foreach (var provider in streamingProviders)
                    {
                        <div class="me-2 mb-2">
                            <img src="@(tmdbImageBaseUrl.Replace("w500", "w185") + provider.LogoPath)"
                                 class="rounded"
                                 style="width: 50px; height: 50px;"
                                 title="@provider.ProviderName"
                                 alt="@provider.ProviderName logo">
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
<hr />

@* --- Action Buttons Section --- *@
<div class="mt-3">
    @if (!isInWishlist && !isInBlacklist)
    {
        <form asp-action="AddToWishlist" method="post" style="display: inline;">
            <input type="hidden" name="tmdbId" value="@Model.Id" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <button type="submit" class="btn btn-success">
                <i class="bi bi-plus-square"></i> Add to Wishlist
            </button>
        </form>
        <form asp-action="AddToBlacklist" method="post" style="display: inline;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tmdbId" value="@Model.Id" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <button type="submit" class="btn btn-danger ms-2">
                <i class="bi bi-slash-circle"></i> Add to Blacklist
            </button>
        </form>
    }
    else if (isInWishlist)
    {
        <span class="badge bg-primary">In Wishlist</span>
        <small class="text-muted ms-2">Remove from wishlist to add to blacklist</small>
    }
    else if (isInBlacklist)
    {
        <span class="badge bg-danger">Blacklisted</span>
        <small class="text-muted ms-2">Remove from blacklist to add to wishlist</small>
    }
    <a asp-action="Suggest" class="btn btn-outline-secondary ms-3">Back to Suggestions</a>
</div>