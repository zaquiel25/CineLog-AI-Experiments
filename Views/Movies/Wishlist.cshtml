@model Ezequiel_Movies.Helpers.PaginatedList<Ezequiel_Movies.Models.WishlistViewModel>

@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "My Wishlist";
    var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/w185";
}



<div class="professional-title-section">
    <div class="title-container-professional">
        <h1 class="page-title-professional">My Wishlist</h1>
    </div>
    <hr />
    
    <p class="text-muted mb-4">Your curated list of films to watch</p>
</div>

<form asp-controller="Movies" asp-action="Wishlist" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by Title..." />
        <button type="submit" class="btn btn-info">Search</button>
        <a asp-action="Wishlist" class="btn btn-secondary ms-1">Clear Search</a>
    </div>
</form>
<div class="mb-3 d-flex justify-content-end">
    <form asp-controller="Movies" asp-action="Wishlist" method="get" class="d-inline">
        <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]" />
        <select name="sortOrder" class="form-select d-inline w-auto me-2" onchange="this.form.submit()">
            <option value="title_asc" selected="@(ViewData["CurrentSort"] as string == "title_asc" ? "selected" : null)">Sort by Title (A-Z)</option>
            <option value="title_desc" selected="@(ViewData["CurrentSort"] as string == "title_desc" ? "selected" : null)">Sort by Title (Z-A)</option>
            <option value="Date" selected="@(ViewData["CurrentSort"] as string == "Date" ? "selected" : null)">Sort by Date Added (Oldest)</option>
            <option value="date_desc" selected="@(ViewData["CurrentSort"] == null || ViewData["CurrentSort"] as string == "date_desc" ? "selected" : null)">Sort by Date Added (Newest)</option>
        </select>
    </form>
</div>

@if (!Model.Any())
{
    <p>Your wishlist is empty. Find a movie from the <a asp-action="Suggest">suggestions page</a>!</p>
}
else
{
    <div id="wishlist-container" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var wishlistItem in Model)
        {
            <div class="col">
                <div class="card h-100 mb-3 shadow-sm border-secondary movie-card">
                    <a asp-controller="Movies" asp-action="Preview" asp-route-tmdbId="@wishlistItem.TmdbId" class="text-decoration-none" style="display:block; height:100%;">
                        <div class="card-img-top text-center" style="background-color: #212529; height: 275px;">
                            @if (!string.IsNullOrEmpty(wishlistItem.PosterPath))
                            {
                                <img src="@(tmdbImageBaseUrl + wishlistItem.PosterPath)" alt="@wishlistItem.Title Poster" style="height: 100%; width: 100%; object-fit: contain;">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100">
                                    <span class="text-muted" style="font-size:0.8rem;">No Poster</span>
                                </div>
                            }
                        </div>
                    </a>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">
                            <a asp-controller="Movies" asp-action="Preview" asp-route-tmdbId="@wishlistItem.TmdbId" class="link-as-text">
                                @wishlistItem.Title
                            </a>
                        </h5>
                        <p class="card-text">
                            <small class="text-muted">
                                @if (!string.IsNullOrEmpty(wishlistItem.Director) && wishlistItem.Director != "Director TBD") {
                                    <text>Directed by @wishlistItem.Director &bull; </text>
                                }
                                @wishlistItem.ReleasedYear
                            </small>
                        </p>
                        <div class="mt-auto">
                            <a asp-controller="Movies" asp-action="Add" asp-route-tmdbId="@wishlistItem.TmdbId" class="btn btn-success btn-sm position-relative" style="z-index:2;">
                                <i class="bi bi-check-lg"></i> I've Watched It
                            </a>
                            <button type="button" class="btn btn-danger btn-sm remove-from-wishlist" data-tmdb-id="@wishlistItem.TmdbId">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        }
    </div>

<script>
// Copilot AJAX Wishlist Removal
document.addEventListener('click', async function (e) {
    if (e.target.closest('.remove-from-wishlist')) {
        const btn = e.target.closest('.remove-from-wishlist');
        const card = btn.closest('.movie-card');
        const tmdbId = btn.getAttribute('data-tmdb-id');
        btn.disabled = true;
        // Get anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        try {
            const response = await fetch('/Movies/RemoveFromWishlist', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: `tmdbId=${encodeURIComponent(tmdbId)}&__RequestVerificationToken=${encodeURIComponent(token)}`,
                credentials: 'same-origin'
            });
            const rawText = await response.text();
            let data;
            try {
                data = JSON.parse(rawText);
            } catch (jsonErr) {
                showTempAlert('Non-JSON response: ' + rawText, 'danger');
                btn.disabled = false;
                return;
            }
            if (!response.ok) {
                showTempAlert('Server error: ' + (data.message || rawText), 'danger');
                btn.disabled = false;
                return;
            }
            if (data.success) {
                card.classList.add('fade-out');
                setTimeout(() => {
                    card.remove();
                    // Check if any cards remain
                    const container = document.getElementById('wishlist-container');
                    if (!container.querySelector('.movie-card')) {
                        container.innerHTML = '<div class="alert alert-info mt-4">Your wishlist is empty. Find a movie from the suggestions page!</div>';
                    }
                }, 300);
            } else {
                showTempAlert(data.message || 'Failed to remove movie.', 'danger');
                btn.disabled = false;
            }
        } catch (err) {
            showTempAlert('Network/JS error: ' + (err && err.message ? err.message : err), 'danger');
            btn.disabled = false;
        }
    }
});

function showTempAlert(message, type) {
    let alert = document.createElement('div');
    alert.className = `alert alert-${type} position-fixed top-0 start-50 translate-middle-x mt-3`;
    alert.style.zIndex = 2000;
    alert.textContent = message;
    document.body.appendChild(alert);
    setTimeout(() => alert.remove(), 2200);
}
</script>


    <!-- Pagination -->
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Wishlist"
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-sortOrder="@ViewData["CurrentSort"]">Previous</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Previous</span>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Wishlist"
                       asp-route-pageNumber="@i"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-sortOrder="@ViewData["CurrentSort"]">@i</a>
                </li>
            }

            @if (Model.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Wishlist"
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-sortOrder="@ViewData["CurrentSort"]">Next</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Next</span>
                </li>
            }
        </ul>
    </nav>
}
