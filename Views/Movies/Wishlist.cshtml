@model IEnumerable<Ezequiel_Movies1.Models.Entities.WishlistItem>
@{
    ViewData["Title"] = "My Wishlist";
    var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/w185";
}


<div class="d-flex align-items-center mb-2">
    <h1 class="mb-0">My Wishlist</h1>
</div>
<hr />

<form asp-controller="Movies" asp-action="Wishlist" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by Title..." />
        <button type="submit" class="btn btn-info">Search</button>
        <a asp-action="Wishlist" class="btn btn-secondary ms-1">Clear Search</a>
    </div>
</form>
<div class="mb-3 d-flex justify-content-end">
    <form asp-controller="Movies" asp-action="Wishlist" method="get" class="d-inline">
        <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]" />
        <select name="sortOrder" class="form-select d-inline w-auto me-2" onchange="this.form.submit()">
            <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Sort by Title (A-Z)</option>
            <option value="title_desc" selected="@(ViewData["CurrentSort"] as string == "title_desc" ? "selected" : null)">Sort by Title (Z-A)</option>
            <option value="Date" selected="@(ViewData["CurrentSort"] as string == "Date" ? "selected" : null)">Sort by Date Added (Oldest)</option>
            <option value="date_desc" selected="@(ViewData["CurrentSort"] as string == "date_desc" ? "selected" : null)">Sort by Date Added (Newest)</option>
        </select>
    </form>
</div>

@if (!Model.Any())
{
    <p>Your wishlist is empty. Find a movie from the <a asp-action="Suggest">suggestions page</a>!</p>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-img-top text-center" style="background-color: #212529; height: 275px;">
                        @if (!string.IsNullOrEmpty(item.PosterPath))
                        {
                            <img src="@(tmdbImageBaseUrl + item.PosterPath)" alt="@item.Title Poster" style="height: 100%; width: 100%; object-fit: contain;">
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <span class="text-muted" style="font-size:0.8rem;">No Poster</span>
                            </div>
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title">@item.Title <small class="text-muted">(@item.ReleasedYear)</small></h6>
                        <div class="mt-auto">
                            <a asp-controller="Movies" asp-action="Add" asp-route-tmdbId="@item.TmdbId" class="btn btn-success btn-sm">
                                <i class="bi bi-check-lg"></i> I've Watched It
                            </a>
                            <form asp-action="RemoveFromWishlist" asp-route-tmdbId="@item.TmdbId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm ms-1"
                                        onclick="return confirm('Are you sure you want to remove \'@item.Title?.Replace("'", "\\'")\' from your wishlist?');"
                                        title="Remove from wishlist">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}