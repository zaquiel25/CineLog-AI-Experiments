@model Ezequiel_Movies.Helpers.PaginatedList<Ezequiel_Movies.Models.BlacklistViewModel>

@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "My Blacklist";
    var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/w185";
    
    // FEATURE: Current sort display mapping for legend
    var currentSortDisplay = ViewData["CurrentSort"]?.ToString() switch
    {
        "director_asc" => "Director A-Z",
        "director_desc" => "Director Z-A", 
        "title_asc" => "Title A-Z",
        "title_desc" => "Title Z-A",
        "Date" => "Date Added (Oldest First)",
        "date_desc" => "Date Added (Newest First)",
        _ => "Date Added (Newest First)"
    };
}

<div class="professional-title-section">
    <div class="title-container-professional">
        <h1 class="page-title-professional">My Blacklist</h1>
    </div>
    <hr />
    
    <p class="text-muted mb-4">Your 'no thanks' list</p>
</div>

<form asp-controller="Movies" asp-action="Blacklist" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by Title..." />
        <button type="submit" class="btn btn-info">Search</button>
        <a asp-action="Blacklist" class="btn btn-secondary ms-1">Clear Search</a>
    </div>
</form>
@* FEATURE: Unified sort dropdown with AJAX functionality matching Collection/Journal views *@
<div class="mb-3 d-flex justify-content-end align-items-center">
    <div class="dropdown me-2">
        <button class="btn btn-outline-secondary dropdown-toggle" 
                type="button" 
                id="sortDropdown" 
                data-bs-toggle="dropdown" 
                aria-expanded="false">
            <i class="fas fa-sort me-1"></i>
        </button>
        <ul class="dropdown-menu" aria-labelledby="sortDropdown">
            @* FIX: Toggle pattern like Journal/Collection - click same option to change order *@
            <li>
                <a class="dropdown-item" 
                   href="@Url.Action("Blacklist", new { sortOrder = ViewData["DirectorSortParm"], searchString = ViewData["CurrentFilter"] })"
                   data-sort-link="true">
                    Director
                </a>
            </li>
            <li>
                <a class="dropdown-item" 
                   href="@Url.Action("Blacklist", new { sortOrder = ViewData["DateSortParm"], searchString = ViewData["CurrentFilter"] })"
                   data-sort-link="true">
                    Date Added
                </a>
            </li>
            <li>
                <a class="dropdown-item" 
                   href="@Url.Action("Blacklist", new { sortOrder = ViewData["TitleSortParm"], searchString = ViewData["CurrentFilter"] })"
                   data-sort-link="true">
                    Title
                </a>
            </li>
        </ul>
    </div>
</div>

@* FEATURE: Sort indicator legend like Journal/Collection views *@
<div class="mb-3">
    <small class="text-muted">
        <i class="fas fa-sort me-1"></i>Sorted by: <strong>@currentSortDisplay</strong>
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
        {
            <span class="ms-2">| <i class="fas fa-search me-1"></i>"@ViewData["CurrentFilter"]"</span>
        }
    </small>
</div>

@if (!Model.Any())
{
    <p>Your blacklist is empty. Movies you add here will not appear in your suggestions.</p>
}
else
{
    <div id="blacklist-container" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 blacklist-movie-card">
                    <div class="card-img-top text-center" style="background-color: #2a1f1f; height: 265px;">
                        @if (!string.IsNullOrEmpty(item.PosterUrl))
                        {
                            <a asp-controller="Movies" asp-action="Preview" asp-route-tmdbId="@item.TmdbId">
                                <img src="@(tmdbImageBaseUrl + item.PosterUrl)" alt="@item.Title Poster" style="height: 100%; width: 100%; object-fit: contain;">
                            </a>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <span class="text-muted" style="font-size:0.8rem;">No Poster</span>
                            </div>
                        }
                    </div>
                    <div class="card-body d-flex flex-column position-relative">
                        <h5 class="card-title mb-1">
                            <a asp-controller="Movies" asp-action="Preview" asp-route-tmdbId="@item.TmdbId" class="link-as-text">
                                @item.Title
                            </a>
                        </h5>
                        <p class="card-text">
                            <small class="text-muted">
                                @if (!string.IsNullOrEmpty(item.Director) && item.Director != "Unknown (TMDB)")
                                {
                                    <text>Directed by @item.Director</text>
                                    @if (item.ReleasedYear != 0)
                                    {
                                        <text> &bull; @item.ReleasedYear</text>
                                    }
                                }
                                else if (item.ReleasedYear != 0)
                                {
                                    <text>@item.ReleasedYear</text>
                                }
                                else
                                {
                                    <text>Added on @item.BlacklistedDate.ToString("MM/dd/yyyy")</text>
                                }
                            </small>
                        </p>
                        <div class="mt-auto">
                            <button type="button" class="btn btn-danger btn-sm remove-from-blacklist" data-tmdb-id="@item.TmdbId">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

<script>
// Copilot AJAX Blacklist Removal
document.addEventListener('click', async function (e) {
    if (e.target.closest('.remove-from-blacklist')) {
        const btn = e.target.closest('.remove-from-blacklist');
        // FIX: Target correct CSS class for blacklist movie cards
        const card = btn.closest('.blacklist-movie-card');
        const tmdbId = btn.getAttribute('data-tmdb-id');
        btn.disabled = true;
        // Get anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        try {
            const response = await fetch('/Movies/RemoveFromBlacklist', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: `tmdbId=${encodeURIComponent(tmdbId)}&__RequestVerificationToken=${encodeURIComponent(token)}`,
                credentials: 'same-origin'
            });
            const rawText = await response.text();
            let data;
            try {
                data = JSON.parse(rawText);
            } catch (jsonErr) {
                showTempAlert('Non-JSON response: ' + rawText, 'danger');
                btn.disabled = false;
                return;
            }
            if (!response.ok) {
                showTempAlert('Server error: ' + (data.message || rawText), 'danger');
                btn.disabled = false;
                return;
            }
            if (data.success) {
                card.classList.add('fade-out');
                setTimeout(() => {
                    card.remove();
                    // Check if any cards remain
                    const container = document.getElementById('blacklist-container');
                    // FIX: Check for remaining blacklist cards using correct CSS class
                    if (!container.querySelector('.blacklist-movie-card')) {
                        container.innerHTML = '<div class="alert alert-info mt-4">Your blacklist is empty. Find a movie from the suggestions page!</div>';
                    }
                }, 300);
            } else {
                showTempAlert(data.message || 'Failed to remove movie.', 'danger');
                btn.disabled = false;
            }
        } catch (err) {
            showTempAlert('Network/JS error: ' + (err && err.message ? err.message : err), 'danger');
            btn.disabled = false;
        }
    }
});

function showTempAlert(message, type) {
    let alert = document.createElement('div');
    alert.className = `alert alert-${type} position-fixed top-0 start-50 translate-middle-x mt-3`;
    alert.style.zIndex = 2000;
    alert.textContent = message;
    document.body.appendChild(alert);
    setTimeout(() => alert.remove(), 2200);
}

// FEATURE: AJAX sorting functionality for Blacklist page - unified with Collection/Journal pattern
document.addEventListener('click', async function(e) {
    const clickedLink = e.target.closest('.dropdown-item');
    if (!clickedLink || !clickedLink.hasAttribute('data-sort-link')) return;
    
    e.preventDefault();
    console.log('AJAX sort request initiated for:', clickedLink.href);
    
    try {
        const response = await fetch(clickedLink.href, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        if (!response.ok) {
            console.error('AJAX response error:', response.status);
            return;
        }
        
        const html = await response.text();
        console.log('AJAX response received, updating container');
        
        // PERFORMANCE: Target container specifically to preserve main element classes
        const currentMain = document.querySelector('main');
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = html;
        const newMain = tempDiv.querySelector('main');
        
        if (currentMain && newMain) {
            const currentContainer = currentMain.querySelector('.container');
            const newContainer = newMain.querySelector('.container');
            if (currentContainer && newContainer) {
                currentContainer.innerHTML = newContainer.innerHTML;
                console.log('AJAX content replacement successful');
            }
        }
        
        // FIX: Update URL without page refresh for proper browser navigation
        history.pushState(null, '', clickedLink.href);
        
    } catch (error) {
        console.error('AJAX sorting error:', error);
        showTempAlert('Sorting failed. Please try again.', 'danger');
    }
});
</script>
    </div>

    <!-- Pagination -->
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Blacklist"
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-sortOrder="@ViewData["CurrentSort"]">Previous</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Previous</span>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Blacklist"
                       asp-route-pageNumber="@i"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-sortOrder="@ViewData["CurrentSort"]">@i</a>
                </li>
            }

            @if (Model.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Blacklist"
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-sortOrder="@ViewData["CurrentSort"]">Next</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Next</span>
                </li>
            }
        </ul>
    </nav>
}
