@model Ezequiel_Movies1.Models.Entities.Movies

@{
    ViewData["Title"] = Model.Title;
    var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/w500"; // Larger poster size
}

<div>
    <h1 class="display-4">@Model.Title</h1>
    <hr />
    <div class="row">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.PosterPath))
            {
                <img src="@(tmdbImageBaseUrl + Model.PosterPath)" class="img-fluid rounded shadow-sm" alt="@Model.Title Poster">
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center bg-light rounded shadow-sm" style="width: 100%; height: 450px; border: 1px dashed #ccc;">
                    <span class="text-muted">No Poster Available</span>
                </div>
            }
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Director</dt>
                <dd class="col-sm-9">@Model.Director</dd>

                <dt class="col-sm-3">Released</dt>
                <dd class="col-sm-9">@(Model.ReleasedYear.HasValue ? Model.ReleasedYear.Value.ToString() : "N/A")</dd>

                <dt class="col-sm-3">Genres</dt>
                <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Genres) ? "N/A" : Model.Genres)</dd>

                <dt class="col-sm-3">Date Watched</dt>
                <dd class="col-sm-9">@(Model.DateWatched.HasValue ? Model.DateWatched.Value.ToString("D") : "N/A")</dd>

                <dt class="col-sm-3">Watched At</dt>
                <dd class="col-sm-9">@(Model.WatchedLocation.HasValue ? Model.WatchedLocation.ToString() : "-")</dd>

                <dt class="col-sm-3">Your Rating</dt>
                <dd class="col-sm-9">
                    @if (Model.UserRating.HasValue && Model.UserRating.Value > 0)
                    {
                        <span class="star-rating-display" style="color: #ffc107; font-size: 1.2rem;">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (Model.UserRating.Value >= i)
                                {<i class="bi bi-star-fill"></i> }
                                else if (Model.UserRating.Value >= (i - 0.5m))
                                { <i class="bi bi-star-half"></i> }
                                else
                                { <i class="bi bi-star"></i>}
                            }
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">Not Rated</span>
                    }
                </dd>
            </dl>

            <h5 class="mt-4">Overview</h5>
            <p>@Model.Overview</p>

            @* VVVV ADD THIS NEW SECTION FOR THE CAST VVVV *@
            @{
                var cast = ViewData["Cast"] as List<Ezequiel_Movies.Models.TmdbApi.TmdbCastPerson>;
            }

            @if (cast != null && cast.Any())
            {
                <h5 class="mt-4">Starring</h5>
                <div class="d-flex">
                    @foreach (var actor in cast)
                    {
                        <div class="text-center me-3">
                            @if (!string.IsNullOrEmpty(actor.ProfilePath))
                            {
                                <img src="@(tmdbImageBaseUrl + actor.ProfilePath)"
                                     class="rounded-circle"
                                     style="width: 60px; height: 60px; object-fit: cover;"
                                     title="@actor.Name"
                                     alt="@actor.Name profile picture">
                            }
                            <p class="mb-0" style="font-size: 0.8rem;">@actor.Name</p>
                        </div>
                    }
                </div>
            }
            @* ^^^^ END OF NEW SECTION ^^^^ *@

            @{
                var watchProviders = ViewData["WatchProviders"] as Dictionary<string, List<Ezequiel_Movies.Models.TmdbApi.ProviderInfo>>;
                bool hasProviders = watchProviders != null && watchProviders.Any(kvp => kvp.Value != null && kvp.Value.Any());
            }
            <h5 class="mt-4">Where to Watch</h5>
            @if (hasProviders && watchProviders != null)
            {
                if (watchProviders.ContainsKey("Streaming"))
                {
                    <div class="provider-category mb-2">
                        <h6>🎬 Stream</h6>
                        <div class="d-flex flex-wrap">
                            @foreach (var provider in watchProviders["Streaming"])
                            {
                                <div class="me-2 mb-2">
                                    <img src="@(tmdbImageBaseUrl + provider.LogoPath)"
                                         class="rounded"
                                         style="width: 50px; height: 50px;"
                                         title="@provider.ProviderName"
                                         alt="@provider.ProviderName logo">
                                </div>
                            }
                        </div>
                    </div>
                }
                if (watchProviders.ContainsKey("Buy"))
                {
                    <div class="provider-category mb-2">
                        <h6>💰 Buy</h6>
                        <div class="d-flex flex-wrap">
                            @foreach (var provider in watchProviders["Buy"])
                            {
                                <div class="me-2 mb-2">
                                    <img src="@(tmdbImageBaseUrl + provider.LogoPath)"
                                         class="rounded"
                                         style="width: 50px; height: 50px;"
                                         title="@provider.ProviderName"
                                         alt="@provider.ProviderName logo">
                                </div>
                            }
                        </div>
                    </div>
                }
                if (watchProviders.ContainsKey("Rent"))
                {
                    <div class="provider-category mb-2">
                        <h6>📱 Rent</h6>
                        <div class="d-flex flex-wrap">
                            @foreach (var provider in watchProviders["Rent"])
                            {
                                <div class="me-2 mb-2">
                                    <img src="@(tmdbImageBaseUrl + provider.LogoPath)"
                                         class="rounded"
                                         style="width: 50px; height: 50px;"
                                         title="@provider.ProviderName"
                                         alt="@provider.ProviderName logo">
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-providers">
                    <p class="text-muted">Not currently available in your region</p>
                </div>
            }
        </div>
@* ^^^^ END OF NEW SECTION ^^^^ *@
    </div>
</div>


<hr />
<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="List" class="btn btn-outline-secondary">Back to List</a>
</div>