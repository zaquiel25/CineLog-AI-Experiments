<script>
// FEATURE: Tab switching with AJAX support
function initializeTabSwitching() {
    const tabButtons = document.querySelectorAll('#viewTabs button[data-view]');
    
    tabButtons.forEach(tab => {
        // Remove any existing event listeners by cloning
        const newTab = tab.cloneNode(true);
        tab.parentNode.replaceChild(newTab, tab);
    });
    
    // Add fresh event listeners to all tab buttons
    document.querySelectorAll('#viewTabs button[data-view]').forEach(tab => {
        tab.addEventListener('click', async function(e) {
            e.preventDefault();
            console.log('Tab switching initiated:', this.dataset.view);
            
            const targetView = this.dataset.view;
            
            // Get current parameters from URL dynamically
            const currentParams = new URLSearchParams(window.location.search);
            const currentSort = currentParams.get('sortOrder') || 'datewatched_desc';
            const currentSearch = currentParams.get('searchString') || '';
            const currentDisplayMode = currentParams.get('displayMode') || 'grid';
            const firstWatchOnly = currentParams.get('firstWatchOnly') || 'false';
            const currentMonthFilter = currentParams.get('monthFilter') || '';
            
            // Build parameters for tab switch
            const params = new URLSearchParams();
            if (currentSort) params.set('sortOrder', currentSort);
            if (currentSearch) params.set('searchString', currentSearch);
            if (currentDisplayMode) params.set('displayMode', currentDisplayMode);
            if (firstWatchOnly === 'true') params.set('firstWatchOnly', 'true');
            if (currentMonthFilter) params.set('monthFilter', currentMonthFilter);
            if (targetView !== 'journal') params.set('view', targetView);
            
            const url = `/Movies/List?${params.toString()}`;
            
            // Show loading state
            const originalText = this.innerHTML;
            this.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Loading...';
            this.disabled = true;
            
            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                });
                
                if (response.ok) {
                    const html = await response.text();
                    
                    // Use same container replacement approach as sorting
                    const currentContainer = document.querySelector('main .container');
                    if (currentContainer) {
                        currentContainer.innerHTML = html;
                        
                        // Update URL
                        window.history.pushState({}, '', url);
                        
                        // Re-initialize all handlers for new content
                        setTimeout(() => {
                            initializeTabSwitching();
                            initializeSearchHandlers();
                        }, 50);
                        
                        console.log('Tab switching completed successfully');
                    } else {
                        console.error('Could not find container element for tab switching');
                        throw new Error('Container element not found');
                    }
                } else {
                    throw new Error('Network response was not ok');
                }
            } catch (error) {
                console.error('Tab switching failed:', error);
                // Reset button and fallback to page navigation
                this.innerHTML = originalText;
                this.disabled = false;
                window.location.href = url;
            }
        });
    });
    
    console.log('Tab switching initialized for', document.querySelectorAll('#viewTabs button[data-view]').length, 'tabs');
}

// Initialize tab switching on page load
document.addEventListener('DOMContentLoaded', function() {
    initializeTabSwitching();
});

// AJAX Movie Deletion (same as journal view)
document.addEventListener('click', async function (e) {
    if (e.target.closest('.delete-movie-btn')) {
        const btn = e.target.closest('.delete-movie-btn');
        const card = btn.closest('.col') || btn.closest('.movie-list-item');
        const movieId = btn.getAttribute('data-movie-id');
        const movieTitle = btn.getAttribute('data-movie-title');
        
        // Confirm deletion
        if (!confirm(`Are you sure you want to delete the latest entry for: '${movieTitle}'?\n\nNote: This will only delete the most recent viewing. Other viewings will remain in your collection.`)) {
            return;
        }
        
        btn.disabled = true;
        
        // Get anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
        try {
            const response = await fetch('/Movies/Delete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: `id=${encodeURIComponent(movieId)}&__RequestVerificationToken=${encodeURIComponent(token)}`,
                credentials: 'same-origin'
            });
            
            const rawText = await response.text();
            let data;
            try {
                data = JSON.parse(rawText);
            } catch (jsonErr) {
                showTempAlert('Non-JSON response: ' + rawText, 'danger');
                btn.disabled = false;
                return;
            }
            
            if (!response.ok) {
                showTempAlert('Server error: ' + (data.message || rawText), 'danger');
                btn.disabled = false;
                return;
            }
            
            if (data.success) {
                // Reload page to update watch counts properly
                showTempAlert(`Latest entry for "${movieTitle}" deleted successfully! Refreshing collection...`, 'success');
                setTimeout(() => {
                    window.location.reload();
                }, 1000);
            } else {
                showTempAlert(data.message || 'Failed to delete movie', 'danger');
                btn.disabled = false;
            }
        } catch (error) {
            console.error('Delete error:', error);
            showTempAlert('Network error. Please try again.', 'danger');
            btn.disabled = false;
        }
    }
});

// Temporary alert function
function showTempAlert(message, type) {
    const alert = document.createElement('div');
    alert.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
    alert.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    alert.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.appendChild(alert);
    setTimeout(() => alert.remove(), 3000);
}

// FEATURE: AJAX month filtering using same approach as sorting
document.addEventListener('click', function(e) {
    const monthLink = e.target.closest('[data-month-filter]');
    if (!monthLink) return;
    
    e.preventDefault();
    console.log('Month filtering initiated:', monthLink.getAttribute('data-month-filter'));
    
    // Show loading state in the clicked month link
    const originalText = monthLink.innerHTML;
    monthLink.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Loading...';
    monthLink.style.pointerEvents = 'none';
    
    // Make AJAX request using the link's href
    fetch(monthLink.href, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
        },
        credentials: 'same-origin'
    })
    .then(response => {
        if (!response.ok) throw new Error('Network response was not ok');
        return response.text();
    })
    .then(html => {
        console.log('AJAX month filtering response received, processing...');
        
        // Use same container replacement approach as sorting and tab switching
        const currentContainer = document.querySelector('main .container');
        
        if (currentContainer) {
            console.log('Replacing container content with month filtered results...');
            
            // Replace container content with AJAX response
            currentContainer.innerHTML = html;
            
            // Update URL without page reload
            const newUrl = new URL(monthLink.href);
            window.history.pushState({}, '', newUrl);
            
            // Re-initialize all handlers for new content
            setTimeout(() => {
                initializeTabSwitching();
                initializeSearchHandlers();
            }, 50);
            
            console.log('Month filtering completed successfully');
        } else {
            console.error('Could not find container element for month filtering');
        }
        
        // Always reset loading state
        monthLink.innerHTML = originalText;
        monthLink.style.pointerEvents = 'auto';
    })
    .catch(error => {
        console.error('AJAX month filtering failed:', error);
        
        // Reset link state on error
        monthLink.innerHTML = originalText;
        monthLink.style.pointerEvents = 'auto';
        
        // FALLBACK: Use standard navigation on AJAX failure
        window.location.href = monthLink.href;
    });
});

