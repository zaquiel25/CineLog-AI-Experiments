    const sortLink = e.target.closest('[data-sort-link]');
    if (!sortLink) return;
    
    e.preventDefault();
    
    // Get current URL parameters dynamically (not from stale server variables)
    const currentParams = new URLSearchParams(window.location.search);
    const url = new URL(sortLink.href);
    const newParams = new URLSearchParams(url.search);
    
    // Show loading state in the clicked sort link
    const originalText = sortLink.innerHTML;
    sortLink.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Sorting...';
    sortLink.style.pointerEvents = 'none';
    
    // Make AJAX request
    fetch(sortLink.href, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
        },
        credentials: 'same-origin'
    })
    .then(response => {
        if (!response.ok) throw new Error('Network response was not ok');
        return response.text();
    })
    .then(html => {
        console.log('AJAX sorting response received, processing...');
        
        // Parse the response
        const parser = new DOMParser();
        const newDoc = parser.parseFromString(html, 'text/html');
        
        // FIXED: Target the container div inside main, since AJAX response is just the view content
        const currentContainer = document.querySelector('main .container');
        
        if (currentContainer) {
            console.log('Replacing container content with AJAX response...');
            
            // The AJAX response should be the complete view content, just replace the container
            currentContainer.innerHTML = html;
            
            // Update URL without page reload
            const newUrl = new URL(window.location);
            newUrl.search = url.search;
            window.history.pushState({}, '', newUrl);
            
            console.log('Content replaced successfully');
        } else {
            console.error('Could not find container element');
        }
        
        // Always reset loading state
        sortLink.innerHTML = originalText;
        sortLink.style.pointerEvents = 'auto';
        
        // Re-initialize all handlers after content replacement
        setTimeout(() => {
            initializeTabSwitching();
            initializeSearchHandlers();
        }, 50);
        
        console.log('AJAX sorting completed successfully');
    })
    .catch(error => {
        console.error('AJAX sorting failed:', error);
        
        // Reset link state on error
        sortLink.innerHTML = originalText;
        sortLink.style.pointerEvents = 'auto';
        
        // FALLBACK: Use standard navigation on AJAX failure
        window.location.href = sortLink.href;
    });
});

/**
 * FEATURE: AJAX Search Form Handler for Collection View - Prevents Page Reload During Search Operations
 *
 * This function handles search form submission and search clearing without page reloads.
 * It preserves all current URL parameters and maintains collection view state during search operations.
 *
 * CRITICAL: Re-initialized after every AJAX content update to prevent event handler loss.
 */
function initializeSearchHandlers() {
    const searchForm = document.getElementById('searchForm');
    const clearSearchButton = document.getElementById('clearSearchButton');

    // FEATURE: AJAX form submission for search
    if (searchForm) {
        // Remove existing listeners by cloning to prevent memory leaks
        const newSearchForm = searchForm.cloneNode(true);
        searchForm.parentNode?.replaceChild(newSearchForm, searchForm);

        newSearchForm.addEventListener('submit', async function(e) {
            e.preventDefault();

            const searchButton = this.querySelector('#searchButton');
            const searchInput = this.querySelector('input[name="searchString"]');
            const searchTerm = searchInput?.value?.trim() || '';

            console.log('AJAX collection search initiated:', searchTerm);

            // Get current URL parameters to preserve state
            const currentParams = new URLSearchParams(window.location.search);
            const currentDisplayMode = currentParams.get('displayMode') || 'grid';
            const currentSort = currentParams.get('sortOrder') || 'datewatched_desc';
            const currentMonthFilter = currentParams.get('monthFilter') || '';

            // Build search URL with preserved parameters for collection view
            const params = new URLSearchParams();
            if (currentSort) params.set('sortOrder', currentSort);
            if (searchTerm) params.set('searchString', searchTerm);
            params.set('view', 'collection'); // Always maintain collection view
            if (currentDisplayMode !== 'grid') params.set('displayMode', currentDisplayMode);
            if (currentMonthFilter) params.set('monthFilter', currentMonthFilter);

            const searchUrl = `/Movies/List?${params.toString()}`;

            // Show loading state
            const originalButtonText = searchButton.innerHTML;
            searchButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Searching...';
            searchButton.disabled = true;

            try {
                const response = await fetch(searchUrl, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                });

                if (response.ok) {
                    const html = await response.text();

                    // Update container content using established pattern
                    const currentContainer = document.querySelector('main .container');
                    if (currentContainer) {
                        currentContainer.innerHTML = html;

                        // Update URL without page reload
                        window.history.pushState(null, '', searchUrl);

                        // Re-initialize all handlers after AJAX update
                        setTimeout(() => {
                            initializeTabSwitching();
                            initializeSearchHandlers();
                        }, 50);

                        console.log('AJAX collection search completed successfully');
                    }
                } else {
                    console.error('AJAX collection search request failed:', response.status);
                    // Fallback to standard form submission
                    searchButton.innerHTML = originalButtonText;
                    searchButton.disabled = false;
                    this.submit();
                }
            } catch (error) {
                console.error('AJAX collection search error:', error);
                // Fallback to standard form submission
                searchButton.innerHTML = originalButtonText;
                searchButton.disabled = false;
                this.submit();
            }
        });

        console.log('Collection search form AJAX handler initialized');
    }
}

// FEATURE: Event delegation for clear search button in collection view (handles dynamically shown/hidden buttons)
document.addEventListener('click', async function(e) {
    const clearButton = e.target.closest('#clearSearchButton');
    if (!clearButton) return;

    e.preventDefault();
    console.log('AJAX collection clear search initiated via event delegation');

    // Show loading state
    const originalButtonText = clearButton.innerHTML;
    clearButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Clearing...';
    clearButton.style.pointerEvents = 'none';

    try {
        const response = await fetch(clearButton.href, {
            method: 'GET',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin'
        });

        if (response.ok) {
            const html = await response.text();

            // Update container content using established pattern
            const currentContainer = document.querySelector('main .container');
            if (currentContainer) {
                currentContainer.innerHTML = html;

                // Update URL without page reload
                const newUrl = new URL(clearButton.href);
                window.history.pushState(null, '', newUrl);

                // Re-initialize all handlers after AJAX update
                setTimeout(() => {
                    initializeTabSwitching();
                    initializeSearchHandlers();
                }, 50);

                console.log('AJAX collection clear search completed successfully via event delegation');
            }
        } else {
            console.error('AJAX collection clear search request failed:', response.status);
            // Fallback to standard navigation
            clearButton.innerHTML = originalButtonText;
            clearButton.style.pointerEvents = 'auto';
            window.location.href = clearButton.href;
        }
    } catch (error) {
        console.error('AJAX collection clear search error:', error);
        // Fallback to standard navigation
        clearButton.innerHTML = originalButtonText;
        clearButton.style.pointerEvents = 'auto';
        window.location.href = clearButton.href;
    }
});

// Initialize search handlers on page load
document.addEventListener('DOMContentLoaded', function() {
    initializeSearchHandlers();
});

</script>