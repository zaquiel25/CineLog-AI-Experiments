// FEATURE: Enhanced Collection Analytics Dashboard Interactions
document.addEventListener('DOMContentLoaded', function() {
    // Only run if we're on collection view with analytics
    if (!document.querySelector('.collection-analytics-dashboard')) return;
    
    // Animate progress bars on load
    const progressBars = document.querySelectorAll('.progress-bar');
    progressBars.forEach((bar, index) => {
        const width = bar.style.width;
        bar.style.width = '0%';
        setTimeout(() => {
            bar.style.width = width;
        }, 500 + (index * 200));
    });
    
    // FEATURE: Dashboard number counter animation
    const animateNumbers = () => {
        const numberElements = document.querySelectorAll('.analytics-number');
        numberElements.forEach(element => {
            const originalText = element.textContent;
            const finalNumber = parseFloat(originalText) || 0;
            let currentNumber = 0;
            const increment = finalNumber / 50; // 50 steps for smooth animation
            
            const timer = setInterval(() => {
                currentNumber += increment;
                if (currentNumber >= finalNumber) {
                    currentNumber = finalNumber;
                    clearInterval(timer);
                    element.textContent = originalText; // Restore original formatting
                    return;
                }
                
                if (Number.isInteger(finalNumber)) {
                    element.textContent = Math.floor(currentNumber);
                } else {
                    element.textContent = currentNumber.toFixed(1);
                }
            }, 30);
        });
    };
    
    // Add click interactions to analytics cards
    const analyticsCards = document.querySelectorAll('.analytics-card');
    analyticsCards.forEach(card => {
        card.addEventListener('click', function() {
            // Add subtle click feedback
            const originalTransform = this.style.transform;
            this.style.transform = 'translateY(-2px) scale(1.01)';
            setTimeout(() => {
                this.style.transform = originalTransform;
            }, 150);
        });
        
        // Add keyboard accessibility
        card.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
                this.click();
            }
        });
        
        // Make cards focusable
        card.setAttribute('tabindex', '0');
    });
    
    // Enhanced hover effects for insight items
    const insightItems = document.querySelectorAll('.insight-item');
    insightItems.forEach(item => {
        item.addEventListener('mouseenter', function() {
            this.style.background = 'rgba(212, 175, 55, 0.15)';
            this.style.borderLeftColor = '#d4af37';
        });
        
        item.addEventListener('mouseleave', function() {
            this.style.background = 'rgba(255, 255, 255, 0.05)';
            this.style.borderLeftColor = 'transparent';
        });
    });
    
    // Start animations after a short delay for better visual flow
    setTimeout(animateNumbers, 800);
});

/**
 * FEATURE: First Watch Only checkbox handler - AJAX implementation for seamless filtering
 * 
 * This function handles the advanced search "Show first watches only" checkbox functionality.
 * It preserves all current URL parameters while toggling the firstWatchOnly filter state.
 * 
 * CRITICAL: This function gets re-initialized after every AJAX operation to prevent
 * event handler loss during dynamic content updates.
 */
function initializeFirstWatchOnly() {
    const firstWatchCheckbox = document.getElementById('firstWatchOnly');
    if (firstWatchCheckbox) {
        // SECURITY: Remove existing listeners by cloning to prevent memory leaks
        const newCheckbox = firstWatchCheckbox.cloneNode(true);
        firstWatchCheckbox.parentNode?.replaceChild(newCheckbox, firstWatchCheckbox);
        
        newCheckbox.addEventListener('change', async function() {
            console.log('First Watch Only checkbox changed:', this.checked);
            
            // FEATURE: Preserve all current URL parameters during filter toggle
            const currentParams = new URLSearchParams(window.location.search);
            const currentSort = currentParams.get('sortOrder') || 'datewatched_desc';
            const currentSearch = currentParams.get('searchString') || '';
            const currentView = currentParams.get('view') || 'journal';
            const currentDisplayMode = currentParams.get('displayMode') || 'grid';
            const currentMonthFilter = currentParams.get('monthFilter') || '';
            
            // ENHANCEMENT: Build new URL with conditional firstWatchOnly parameter
            const params = new URLSearchParams();
            if (currentSort) params.set('sortOrder', currentSort);
            if (currentSearch) params.set('searchString', currentSearch);
            if (currentView !== 'journal') params.set('view', currentView);
            if (currentDisplayMode !== 'grid') params.set('displayMode', currentDisplayMode);
            if (currentMonthFilter) params.set('monthFilter', currentMonthFilter);
            if (this.checked) params.set('firstWatchOnly', 'true');
            
            const url = `/Movies/List?${params.toString()}`;
            console.log('First Watch Only - Making AJAX request to:', url);
            
            try {
                // Show loading state on checkbox
                const originalLabel = this.nextElementSibling.textContent;
                this.nextElementSibling.textContent = 'Filtering...';
                this.disabled = true;
                
                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                });
                
                if (response.ok) {
                    const html = await response.text();
                    
                    // Update container content (same approach as sorting and tab switching)
                    const currentContainer = document.querySelector('main .container');
                    if (currentContainer) {
                        currentContainer.innerHTML = html;
                        
                        // Update URL without page reload
                        window.history.pushState(null, '', url);
                        
                        // Re-initialize all handlers after AJAX update
                        setTimeout(() => {
                            initializeTabSwitching();
                            initializeFirstWatchOnly();
                            initializeSearchHandlers();
                        }, 50);
                        
                        console.log('First Watch Only - AJAX update completed successfully');
                    }
                } else {
                    console.error('First Watch Only - AJAX request failed:', response.status);
                    // Fallback to page refresh on error
                    window.location.href = url;
                }
            } catch (error) {
                console.error('First Watch Only - Error during AJAX request:', error);
                // Fallback to page refresh on error
                window.location.href = url;
            }
        });
        console.log('First Watch Only checkbox handler initialized');
    }
}

