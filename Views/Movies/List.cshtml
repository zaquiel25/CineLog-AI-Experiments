@using Ezequiel_Movies.Helpers
@model PaginatedList<Ezequiel_Movies1.Models.Entities.Movies>

@{
    ViewData["Title"] = "My Movies - CineLog";
    var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/";
    var posterSize = "w185";
}

<div class="d-flex align-items-center mb-2">
    <h1 class="mb-0">My Movies</h1>
    @if (ViewData["MovieCount"] is int movieCount)
    {
        @* Display the total movie count in a badge next to the title *@
        <span class="badge bg-secondary ms-3" style="font-size: 1rem;">@movieCount</span>
    }
</div>
<hr />


<div class="row mb-4">
    <div class="col-md-8">
        <form method="get" action="@Url.Action("List")">
            <div class="input-group">
                <input type="text" 
                       name="searchString" 
                       value="@ViewData["CurrentFilter"]" 
                       class="form-control" 
                       placeholder="Search by Title, Director, or Year..." />
                <input type="hidden" name="sortOrder" value="@ViewData["CurrentSort"]" />
                <button type="submit" class="btn btn-primary">Search</button>
                <a href="@Url.Action("List")" class="btn btn-secondary">Clear Search</a>
            </div>
        </form>
    </div>
    <div class="col-md-4">
        <div class="dropdown">
            <button class="btn dropdown-toggle w-100" 
                    type="button" 
                    id="sortDropdown" 
                    data-bs-toggle="dropdown" 
                    aria-expanded="false"
                    style="background-color: #6c757d; color: white; border: 1px solid #5a6268; padding: 8px 12px; font-size: 14px; min-height: 38px; box-shadow: none;">
                <i class="fas fa-sort me-2"></i>Sort By
            </button>
            <ul class="dropdown-menu dropdown-menu-dark w-100" 
                aria-labelledby="sortDropdown">
                <!-- Date Watched -->
                <li>
                    <a class="dropdown-item" 
                       href="@Url.Action("List", new { sortOrder = ViewData["DateSortParm"], searchString = ViewData["CurrentFilter"] })">
                        <i class="fas fa-calendar me-2"></i>Date Watched
                        @if (ViewData["CurrentSort"]?.ToString()?.StartsWith("date") == true)
                        {
                            <span class="float-end">
                                @((ViewData["CurrentSort"]?.ToString() ?? "") == "date_desc" ? "↓" : "↑")
                            </span>
                        }
                    </a>
                </li>
                <!-- Title -->
                <li>
                    <a class="dropdown-item" 
                       href="@Url.Action("List", new { sortOrder = ViewData["TitleSortParm"], searchString = ViewData["CurrentFilter"] })">
                        <i class="fas fa-font me-2"></i>Title
                        @if (ViewData["CurrentSort"]?.ToString()?.StartsWith("title") == true)
                        {
                            <span class="float-end">
                                @((ViewData["CurrentSort"]?.ToString() ?? "") == "title_desc" ? "↓" : "↑")
                            </span>
                        }
                    </a>
                </li>
                <!-- Director -->
                <li>
                    <a class="dropdown-item" 
                       href="@Url.Action("List", new { sortOrder = ViewData["DirectorSortParm"], searchString = ViewData["CurrentFilter"] })">
                        <i class="fas fa-user-tie me-2"></i>Director
                        @if (ViewData["CurrentSort"]?.ToString()?.StartsWith("director") == true)
                        {
                            <span class="float-end">
                                @((ViewData["CurrentSort"]?.ToString() ?? "") == "director_desc" ? "↓" : "↑")
                            </span>
                        }
                    </a>
                </li>
                <!-- Released Year -->
                <li>
                    <a class="dropdown-item" 
                       href="@Url.Action("List", new { sortOrder = ViewData["YearSortParm"], searchString = ViewData["CurrentFilter"] })">
                        <i class="fas fa-clock me-2"></i>Released Year
                        @if (ViewData["CurrentSort"]?.ToString()?.StartsWith("year") == true)
                        {
                            <span class="float-end">
                                @((ViewData["CurrentSort"]?.ToString() ?? "") == "year_desc" ? "↓" : "↑")
                            </span>
                        }
                    </a>
                </li>
                <!-- Rating -->
                <li>
                    <a class="dropdown-item" 
                       href="@Url.Action("List", new { sortOrder = ViewData["RatingSortParm"], searchString = ViewData["CurrentFilter"] })">
                        <i class="fas fa-star me-2"></i>Rating
                        @if (ViewData["CurrentSort"]?.ToString()?.StartsWith("rating") == true)
                        {
                            <span class="float-end">
                                @((ViewData["CurrentSort"]?.ToString() ?? "") == "rating_desc" ? "↓" : "↑")
                            </span>
                        }
                    </a>
                </li>
                <!-- Watched At (Location) -->
                <li>
                    <a class="dropdown-item" 
                       href="@Url.Action("List", new { sortOrder = ViewData["LocationSortParm"], searchString = ViewData["CurrentFilter"] })">
                        <i class="fas fa-map-marker-alt me-2"></i>Watched At
                        @if (ViewData["CurrentSort"]?.ToString()?.StartsWith("location") == true)
                        {
                            <span class="float-end">
                                @((ViewData["CurrentSort"]?.ToString() ?? "") == "location_desc" ? "↓" : "↑")
                            </span>
                        }
                    </a>
                </li>
            </ul>
        </div>
    </div>
</div>
<p>
    <a asp-controller="Movies" asp-action="Add" class="btn btn-success mb-3">Add New Movie</a>
</p>


@{
    var currentSortDisplay = ViewData["CurrentSort"]?.ToString() switch
    {
        "title_asc" => "Title (A-Z)",
        "title_desc" => "Title (Z-A)",
        "date_asc" => "Date Watched (Oldest First)",
        "date_desc" => "Date Watched (Newest First)",
        "director_asc" => "Director (A-Z)",
        "director_desc" => "Director (Z-A)",
        "year_asc" => "Released Year (Oldest First)",
        "year_desc" => "Released Year (Newest First)",
        "rating_asc" => "Rating (Lowest First)",
        "rating_desc" => "Rating (Highest First)",
        "location_asc" => "Watched At (A-Z)",
        "location_desc" => "Watched At (Z-A)",
        _ => "Date Watched (Newest First)"
    };
}
<div class="mb-3">
    <small class="text-muted">
        <i class="fas fa-sort me-1"></i>Currently sorted by: <strong>@currentSortDisplay</strong>
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
        {
            <span class="ms-2">| <i class="fas fa-search me-1"></i>Filtered by: "@ViewData["CurrentFilter"]"</span>
        }
    </small>
</div>


@if (!Model.Any())
{
    <p>No movies found in your list yet. Why not <a asp-action="Add">add one</a>?</p>
}
else
{
    @* VVVV THIS IS THE CORRECTED GRID STRUCTURE VVVV *@

    @* 1. This 'div' with the 'row' class is the main grid container *@
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

    @foreach (var movie in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @* Poster image *@
                <div class="card-img-top text-center" style="background-color: #212529; height: 275px;">
                    @if (!string.IsNullOrEmpty(movie.PosterPath))
                    {
                        <a asp-action="Details" asp-route-id="@movie.Id">
                            <img src="@(tmdbImageBaseUrl + posterSize + movie.PosterPath)"
                                 alt="@(movie.Title ?? "Movie Poster")"
                                 style="height: 100%; width: 100%; object-fit: contain;">
                        </a>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100">
                            <span class="text-muted" style="font-size:0.8rem;">No Poster</span>
                        </div>
                    }
                </div>

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">
                        <a asp-action="Details" asp-route-id="@movie.Id" class="link-as-text">
                            @(movie.Title ?? "Untitled")
                        </a>
                    </h5>

                    @{
                        var director = movie.Director ?? "Unknown";
                        var year = movie.ReleasedYear?.ToString() ?? "Unknown";
                        var location = movie.WatchedLocation?.ToString() ?? "-";
                        var rating = movie.UserRating ?? 0;
                    }
                    <ul class="list-unstyled mt-2 mb-2" style="font-size: 0.85rem;">
                        <li class="mb-1"><strong>Directed by:</strong> @director</li>
                        <li class="mb-1"><strong>Released:</strong> @year</li>
                        <li class="mb-1"><strong>Watched:</strong> @(movie.DateWatched.HasValue ? movie.DateWatched.Value.ToString("dd/MM/yyyy") : "-")</li>
                        <li class="mb-1"><strong>At:</strong> @(string.IsNullOrWhiteSpace(location) || location == "Unknown" ? "-" : location)</li>
                        @if (movie.IsRewatch)
                        {
                            <li class="mt-1"><span class="badge rounded-pill bg-primary">Rewatched</span></li>
                        }
                        @if (rating > 0)
                        {
                            <li class="mt-1">
                                <span class="star-rating-display" style="color: #ffc107; font-size: 0.9rem;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (rating >= i)
                                        {<i class="bi bi-star-fill"></i> }
                                        else if (rating >= (i - 0.5m))
                                        { <i class="bi bi-star-half"></i> }
                                        else
                                        { <i class="bi bi-star"></i>}
                                    }
                                </span>
                            </li>
                        }
                        else
                        {
                            <li class="mt-1"><strong>Not Rated</strong></li>
                        }
                    </ul>

                    @* No review property on Movies model, so no review display *@

                    <div class="mt-auto">
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@movie.Id">Edit</a>
                        <form asp-action="Delete" asp-route-id="@movie.Id" method="post" style="display: inline; margin-left: 5px;">
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Are you sure you want to delete the movie: \'@(movie.Title ?? "")\'?');">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

    @* ... (Your working Pagination control block goes here) ... *@
}
@* --- VVVV CORRECTED AND SIMPLIFIED PAGINATION CONTROL BLOCK VVVV --- *@
<div class="d-flex justify-content-center mt-4">
    <nav aria-label="Movie list navigation">
        <ul class="pagination">

            @if (Model.HasPreviousPage)
            {
                <li class="page-item">
                    <a asp-action="List"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       class="page-link">
                        Previous
                    </a>
                </li>
            }

            @if (Model.TotalPages > 1)
            {
                <li class="page-item disabled">
                    <span class="page-link" style="color: #6c757d;">Page @Model.PageIndex of @Model.TotalPages</span>
                </li>
            }

            @if (Model.HasNextPage)
            {
                <li class="page-item">
                    <a asp-action="List"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       class="page-link">
                        Next
                    </a>
                </li>
            }

        </ul>
    </nav>
</div>
@* --- ^^^^ END OF PAGINATION CONTROL BLOCK ^^^^ --- *@


@* Optional "Add New Movie" button at the bottom *@
@if (Model.Any())
{
    <div class="mt-4 pt-4 border-top text-center mb-5">
        <a asp-controller="Movies" asp-action="Add" class="btn btn-success btn-lg">
            <i class="bi bi-plus-circle-fill me-2"></i>Add New Movie
        </a>
    </div>
}
