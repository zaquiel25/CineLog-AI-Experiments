<script>
// AJAX Movie Deletion
document.addEventListener('click', async function (e) {
    if (e.target.closest('.delete-movie-btn')) {
        const btn = e.target.closest('.delete-movie-btn');
        const card = btn.closest('.col');
        const movieId = btn.getAttribute('data-movie-id');
        const movieTitle = btn.getAttribute('data-movie-title');
        
        // Confirm deletion
        if (!confirm(`Are you sure you want to delete the movie: '${movieTitle}'?`)) {
            return;
        }
        
        btn.disabled = true;
        
        // Get anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
        try {
            const response = await fetch('/Movies/Delete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: `id=${encodeURIComponent(movieId)}&__RequestVerificationToken=${encodeURIComponent(token)}`,
                credentials: 'same-origin'
            });
            
            const rawText = await response.text();
            let data;
            try {
                data = JSON.parse(rawText);
            } catch (jsonErr) {
                showTempAlert('Non-JSON response: ' + rawText, 'danger');
                btn.disabled = false;
                return;
            }
            
            if (!response.ok) {
                showTempAlert('Server error: ' + (data.message || rawText), 'danger');
                btn.disabled = false;
                return;
            }
            
            if (data.success) {
                // Add fade-out animation
                card.classList.add('fade-out');
                setTimeout(() => {
                    card.remove();
                    
                    // Update movie count badge
                    const countBadge = document.querySelector('.badge.bg-secondary');
                    if (countBadge) {
                        const currentCount = parseInt(countBadge.textContent);
                        const newCount = currentCount - 1;
                        countBadge.textContent = newCount;
                        
                        // If count reaches 0, refresh page to show "no movies" message
                        if (newCount === 0) {
                            window.location.reload();
                        }
                    }
                    
                    // Check if any movie cards remain on current page
                    const container = document.getElementById('movies-grid');
                    if (container && !container.querySelector('.col')) {
                        // No more movies on this page, reload to handle pagination
                        window.location.reload();
                    }
                    
                    showTempAlert(`Movie "${movieTitle}" deleted successfully!`, 'success');
                }, 300);
            } else {
                showTempAlert(data.message || 'Failed to delete movie', 'danger');
                btn.disabled = false;
            }
        } catch (error) {
            console.error('Delete error:', error);
            showTempAlert('Network error. Please try again.', 'danger');
            btn.disabled = false;
        }
    }
});

// FEATURE: Tab switching with AJAX support
function initializeTabSwitching() {
    const tabButtons = document.querySelectorAll('#viewTabs button[data-view]');
    
    tabButtons.forEach(tab => {
        // Remove any existing event listeners by cloning
        const newTab = tab.cloneNode(true);
        tab.parentNode.replaceChild(newTab, tab);
    });
    
    // Add fresh event listeners to all tab buttons
    document.querySelectorAll('#viewTabs button[data-view]').forEach(tab => {
        tab.addEventListener('click', async function(e) {
            e.preventDefault();
            console.log('Tab switching initiated:', this.dataset.view);
            
            const targetView = this.dataset.view;
            
            // Get current parameters from URL dynamically
            const currentParams = new URLSearchParams(window.location.search);
            const currentSort = currentParams.get('sortOrder') || 'datewatched_desc';
            const currentSearch = currentParams.get('searchString') || '';
            const currentDisplayMode = currentParams.get('displayMode') || 'grid';
            const firstWatchOnly = currentParams.get('firstWatchOnly') || 'false';
            const currentMonthFilter = currentParams.get('monthFilter') || '';
            
            // Build parameters for tab switch
            const params = new URLSearchParams();
            if (currentSort) params.set('sortOrder', currentSort);
            if (currentSearch) params.set('searchString', currentSearch);
            if (currentDisplayMode) params.set('displayMode', currentDisplayMode);
            if (firstWatchOnly === 'true') params.set('firstWatchOnly', 'true');
            if (currentMonthFilter) params.set('monthFilter', currentMonthFilter);
            if (targetView !== 'journal') params.set('view', targetView);
            
            const url = `/Movies/List?${params.toString()}`;
            
            // Show loading state
            const originalText = this.innerHTML;
            this.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Loading...';
            this.disabled = true;
            
            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                });
                
                if (response.ok) {
