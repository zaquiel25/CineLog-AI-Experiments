<script>
// AJAX Movie Deletion
document.addEventListener('click', async function (e) {
    if (e.target.closest('.delete-movie-btn')) {
        const btn = e.target.closest('.delete-movie-btn');
        const card = btn.closest('.col');
        const movieId = btn.getAttribute('data-movie-id');
        const movieTitle = btn.getAttribute('data-movie-title');
        
        // Confirm deletion
        if (!confirm(`Are you sure you want to delete the movie: '${movieTitle}'?`)) {
            return;
        }
        
        btn.disabled = true;
        
        // Get anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
        try {
            const response = await fetch('/Movies/Delete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: `id=${encodeURIComponent(movieId)}&__RequestVerificationToken=${encodeURIComponent(token)}`,
                credentials: 'same-origin'
            });
            
            const rawText = await response.text();
            let data;
            try {
                data = JSON.parse(rawText);
            } catch (jsonErr) {
                showTempAlert('Non-JSON response: ' + rawText, 'danger');
                btn.disabled = false;
                return;
            }
            
            if (!response.ok) {
                showTempAlert('Server error: ' + (data.message || rawText), 'danger');
                btn.disabled = false;
                return;
            }
            
            if (data.success) {
                // Add fade-out animation
                card.classList.add('fade-out');
                setTimeout(() => {
                    card.remove();
                    
                    // Update movie count badge
                    const countBadge = document.querySelector('.badge.bg-secondary');
                    if (countBadge) {
                        const currentCount = parseInt(countBadge.textContent);
                        const newCount = currentCount - 1;
                        countBadge.textContent = newCount;
                        
                        // If count reaches 0, refresh page to show "no movies" message
                        if (newCount === 0) {
                            window.location.reload();
                        }
                    }
                    
                    // Check if any movie cards remain on current page
                    const container = document.getElementById('movies-grid');
                    if (container && !container.querySelector('.col')) {
                        // No more movies on this page, reload to handle pagination
                        window.location.reload();
                    }
                    
                    showTempAlert(`Movie "${movieTitle}" deleted successfully!`, 'success');
                }, 300);
            } else {
                showTempAlert(data.message || 'Failed to delete movie', 'danger');
                btn.disabled = false;
            }
        } catch (error) {
            console.error('Delete error:', error);
            showTempAlert('Network error. Please try again.', 'danger');
            btn.disabled = false;
        }
    }
});

// FEATURE: AJAX tab switching for seamless view transitions
document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('#viewTabs button[data-view]');
    
    tabs.forEach(tab => {
        tab.addEventListener('click', async function(e) {
            e.preventDefault();
            
            const targetView = this.dataset.view;
            const currentSort = '@ViewData["CurrentSort"]';
            const currentSearch = '@Html.Raw(ViewData["CurrentFilter"]?.ToString() ?? "")';
            const currentDisplayMode = '@ViewData["CurrentDisplayMode"]';
            const firstWatchOnly = '@Context.Request.Query["firstWatchOnly"]';
            
            // Build URL with current parameters
            const params = new URLSearchParams();
            if (currentSort) params.set('sortOrder', currentSort);
            if (currentSearch) params.set('searchString', currentSearch);
            if (currentDisplayMode && currentDisplayMode !== 'grid') params.set('displayMode', currentDisplayMode);
            if (firstWatchOnly === 'true') params.set('firstWatchOnly', 'true');
            if (targetView !== 'journal') params.set('view', targetView);
            
            const url = '@Url.Action("List")' + (params.toString() ? '?' + params.toString() : '');
            
            try {
                // Use navigation to switch views and maintain state
                window.location.href = url;
            } catch (error) {
                // Fallback to navigation
                window.location.href = url;
            }
        });
    });
});

// Temporary alert function
function showTempAlert(message, type) {
    const alert = document.createElement('div');
    alert.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
    alert.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    alert.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.appendChild(alert);
    setTimeout(() => alert.remove(), 2200);
}

// FEATURE: Smart Timeline Navigator AJAX functionality
document.addEventListener('DOMContentLoaded', function() {
    // Add AJAX handling for timeline filter links
    const timelineLinks = document.querySelectorAll('.timeline-filter');
    
    timelineLinks.forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            
            const monthFilter = this.getAttribute('data-month-filter');
            const currentParams = new URLSearchParams(window.location.search);
            
            // Show loading state in timeline dropdown
            const timelineButton = document.getElementById('timelineDropdown');
            if (timelineButton) {
                timelineButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Loading...';
            }
            
            // Prepare form data for AJAX request
            const formData = new FormData();
            formData.append('monthFilter', monthFilter || '');
            formData.append('sortOrder', currentParams.get('sortOrder') || '');
            formData.append('searchString', currentParams.get('searchString') || '');
            formData.append('pageNumber', '1'); // Reset to first page when filtering
            formData.append('view', '@currentView');
            formData.append('displayMode', '@currentDisplayMode');
            formData.append('firstWatchOnly', currentParams.get('firstWatchOnly') || 'false');
            
            // AJAX request to filter by month
            fetch('@Url.Action("FilterByMonth")', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    return response.text();
                }
                throw new Error('Network response was not ok');
            })
            .then(html => {
                // Replace the entire main content with the filtered results
                const parser = new DOMParser();
                const newDoc = parser.parseFromString(html, 'text/html');
                const newContent = newDoc.querySelector('main') || newDoc.querySelector('body');
                
                if (newContent) {
                    const currentMain = document.querySelector('main') || document.querySelector('body');
                    if (currentMain) {
                        currentMain.innerHTML = newContent.innerHTML;
                        
                        // Update URL to reflect the filter change
                        const newUrl = new URL(window.location);
                        if (monthFilter) {
                            newUrl.searchParams.set('monthFilter', monthFilter);
                        } else {
                            newUrl.searchParams.delete('monthFilter');
                        }
                        newUrl.searchParams.set('pageNumber', '1');
                        window.history.pushState(null, '', newUrl.toString());
                        
                        // Show success message
                        showAlert(monthFilter ? 
                            `Timeline filtered to ${this.textContent.trim().replace(/✓$/, '').trim()}` : 
                            'Timeline filter cleared - showing all months', 
                            'success');
                        
                        // Scroll to top to see filtered results
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                } else {
                    throw new Error('Unable to parse filtered content');
                }
            })
            .catch(error => {
                console.error('Timeline filter error:', error);
                showAlert('Unable to filter timeline. Please try again.', 'danger');
                
                // Reset button state on error
                if (timelineButton) {
                    timelineButton.innerHTML = '<i class="fas fa-calendar-alt me-2"></i>@(ViewData["TimelineNavigator"] is TimelineNavigatorViewModel tl ? tl.SelectedMonthDisplayName : "All Months")';
                }
                
                // FALLBACK: Use standard navigation on AJAX failure
                window.location.href = this.href;
            });
        });
    });
});
</script>
