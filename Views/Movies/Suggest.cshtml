@using Ezequiel_Movies.Models.TmdbApi
@model List<TmdbMovieBrief>

@{
    ViewData["Title"] = "Movie Suggestions";
}

<div class="text-center pt-4">
    <h1 class="display-4 mt-5 mb-3">Find your next movie</h1>
    <p class="lead mb-5">Click a button to get personalized suggestions based on your log.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-9 mb-5">

        @* This is the full grid for all six suggestion buttons *@
        <div class="row justify-content-center g-4">
            <div class="col-lg-4 col-md-6">
                <a asp-action="ShowSuggestions" asp-route-suggestionType="trending" class="suggestion-card card h-100 text-decoration-none">
                    <div class="card-body text-center d-flex flex-column justify-content-center align-items-center p-4">
                        <i class="bi bi-graph-up-arrow display-4 mb-2"></i>
                        <h6 class="card-title mb-0" style="font-weight: 400; font-size: 1.05rem;">Trending Movies</h6>
                        <p class="suggestion-description mt-2" style="font-size: 1.08rem;">See what's popular right now.</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-6">
                <a asp-action="ShowSuggestions" asp-route-suggestionType="director_recent" class="suggestion-card card h-100 text-decoration-none">
                    <div class="card-body text-center d-flex flex-column justify-content-center align-items-center p-4">
                        <i class="bi bi-person-video3 display-4 mb-2"></i>
                        <h6 class="card-title mb-0" style="font-weight: 400; font-size: 1.05rem;">By Director</h6>
                        <p class="suggestion-description mt-2" style="font-size: 1.08rem;">From your recently watched, most frequent, or top-rated directors.</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-6">
                <a asp-action="ShowSuggestions" asp-route-suggestionType="genre_recent" class="suggestion-card card h-100 text-decoration-none">
                    <div class="card-body text-center d-flex flex-column justify-content-center align-items-center p-4">
                        <i class="bi bi-tags display-4 mb-2"></i>
                        <h6 class="card-title mb-0" style="font-weight: 400; font-size: 1.05rem;">By Genre</h6>
                        <p class="suggestion-description mt-2" style="font-size: 1.08rem;">Get suggestions based on genres you've enjoyed.</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-6">
                <a asp-action="ShowSuggestions" asp-route-suggestionType="cast_recent" class="suggestion-card card h-100 text-decoration-none">
                    <div class="card-body text-center d-flex flex-column justify-content-center align-items-center p-4">
                        <i class="bi bi-people display-4 mb-2"></i>
                        <h6 class="card-title mb-0" style="font-weight: 400; font-size: 1.05rem;">By Cast</h6>
                        <p class="suggestion-description mt-2" style="font-size: 1.08rem;">Find movies featuring actors from your logged films.</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-6">
                <a asp-action="ShowSuggestions" asp-route-suggestionType="year_recent" class="suggestion-card card h-100 text-decoration-none">
                    <div class="card-body text-center d-flex flex-column justify-content-center align-items-center p-4">
                        <i class="bi bi-calendar3 display-4 mb-2"></i>
                        <h6 class="card-title mb-0" style="font-weight: 400; font-size: 1.05rem;">By Decade</h6>
                        <p class="suggestion-description mt-2" style="font-size: 1.08rem;">Explore movies from your favorite eras.</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-4 col-md-6">
                <a asp-action="GetSurpriseSuggestion" class="suggestion-card card h-100 text-decoration-none">
                    <div class="card-body text-center d-flex flex-column justify-content-center align-items-center p-4">
                        <i class="bi bi-shuffle display-4 mb-2"></i>
                        <h6 class="card-title mb-0" style="font-weight: 400; font-size: 1.05rem;">Surprise Me!</h6>
                        <p class="suggestion-description mt-2" style="font-size: 1.08rem;">Get a random suggestion based on your taste.</p>
                    </div>
                </a>
            </div>
        </div>

        @{
            var genreList = ViewData["GenreSuggestions"] as List<TmdbGenre>;
            var actorList = ViewData["CastSuggestions"] as List<TmdbCastPerson>;
        }

        @if (Model != null)
        {
            <div id="suggestion-results-area">
                <hr class="my-5">
                <div class="text-center mb-4">
                    <div class="d-flex justify-content-center align-items-center">
                        @if (ViewData["ActorProfilePath"] != null && !string.IsNullOrEmpty(ViewData["ActorProfilePath"]?.ToString()))
                        {
                            var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/w342";
                            <img src="@(tmdbImageBaseUrl + ViewData["ActorProfilePath"])" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;" alt="Profile picture" />
                        }
                        <h4 class="mb-0" style="color: var(--cinelog-gold); font-weight: 600;">@ViewData["SuggestionTitle"]</h4>
                    </div>
                    

@if (Model.Any())
{
    var nextSuggestionType = ViewData["NextSuggestionType"] as string;
    
    @* ---
        Lógica de botones de reshuffle:
        - Si el tipo de sugerencia es "trending", se muestra un botón que dispara un reshuffle AJAX (sin recargar la página).
        - Para otros tipos de sugerencia, se usan enlaces normales que navegan a la acción correspondiente (flujo tradicional).
        - Esto permite un patrón híbrido: AJAX para trending (por performance y experiencia de usuario), navegación normal para el resto.
        - El botón trending usa data-suggestion-type para que el JS pueda distinguir el tipo y disparar el fetch AJAX solo en ese caso.
    *@
    @if (nextSuggestionType == "trending" || (nextSuggestionType != null && nextSuggestionType.StartsWith("cast_")))
    {
        // BOTÓN AJAX PARA TRENDING Y CAST
        <button id="reshuffle-btn" type="button" class="btn btn-outline-light btn-sm mt-2" data-suggestion-type="@(nextSuggestionType.StartsWith("cast_") ? "cast" : "trending")">
            <i class="bi bi-shuffle"></i> Reshuffle
        </button>
    }
    else
    {
        // BOTONES NORMALES PARA OTROS TIPOS
        var nextAction = nextSuggestionType == "surprise_me" ? "GetSurpriseSuggestion" : "ShowSuggestions";
        <a asp-action="@nextAction"
           asp-route-suggestionType="@ViewData["NextSuggestionType"]"
           asp-route-query="@ViewData["NextQuery"]"
           asp-route-page="@ViewData["NextPage"]"
           class="btn btn-sm btn-outline-secondary mt-3">
            <i class="bi bi-arrow-repeat"></i>
            @(nextAction == "GetSurpriseSuggestion" ? "Get Another Surprise" : "Reshuffle")
        </a>
    }
}
                    else if ((bool?)ViewData["ShowAddMovieButton"] == true)
                    {
                        <a asp-controller="Movies" asp-action="Add" class="btn btn-lg btn-success mt-3">
                            <i class="bi bi-plus-circle me-2"></i> Log a Movie
                        </a>
                    }
                    else
                    {
                        <a asp-action="ShowSuggestions"
                           asp-route-suggestionType="@ViewData["NextSuggestionType"]"
                           asp-route-query="@ViewData["NextQuery"]"
                           asp-route-page="@ViewData["NextPage"]"
                           class="btn btn-sm btn-outline-secondary mt-3">
                            <i class="bi bi-arrow-repeat"></i> Reshuffle
                        </a>
                    }
                </div>
            </div>
            @if (Model.Any())
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 justify-content-center">
                    @foreach (var movie in Model)
                    {
                        <partial name="_MovieSuggestionCard" model="movie" />
                    }
                </div>
            }
        }
        else if (genreList != null && genreList.Any())
        {
            <div id="suggestion-results-area">
                <hr class="my-5">
                <div class="text-center mb-4">
                    <h4 style="color: var(--cinelog-gold); font-weight: 600;">@ViewData["SuggestionTitle"]</h4>
                    <p class="text-muted small">Based on genres from your logged movies</p>
                </div>
                <div class="row row-cols-2 row-cols-sm-3 g-3 justify-content-center mb-5">
                    @foreach (var genre in genreList)
                    {
                        <div class="col text-center">
                            <a asp-action="ShowSuggestions" asp-route-suggestionType="movies_by_genre" asp-route-query="@genre.Id" class="btn btn-lg btn-outline-warning w-100 p-3">
                                @genre.Name
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</div>


@section Scripts {
<script>
    /*
     * Patrón híbrido de sugerencias:
     * - Para "Trending", el reshuffle es 100% AJAX: el botón dispara un fetch al endpoint TrendingReshuffle, que devuelve HTML listo para insertar.
     * - Para otros tipos, se usa navegación tradicional (enlaces).
     *
     * ¿Por qué AJAX + HTML y no JSON?:
     * - El renderizado server-side asegura que los posters y paths de imágenes funcionen igual que en el render inicial.
     * - Permite mantener la lógica DRY y la visual consistente usando partial views.
     *
     * Integración AJAX + partial views:
     * - El JS detecta el botón trending por data-suggestion-type.
     * - Hace fetch, reemplaza el grid y re-adjunta event listeners (para que los formularios AJAX sigan funcionando tras el reshuffle).
     * - El resto de botones usan navegación normal.
     *
     * Notas:
     * - Siempre re-adjuntar event listeners tras reemplazar HTML dinámico.
     * - Este patrón es extensible a otros tipos de sugerencia si se desea AJAXizar más adelante.
     */
    document.addEventListener('DOMContentLoaded', function () {
        const resultsContainer = document.getElementById('suggestion-results-area');
        if (resultsContainer) {
            resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        attachEventListeners();
    });

    document.addEventListener('click', function(e) {
        if (e.target && e.target.id === 'reshuffle-btn') {
            e.preventDefault();
            const suggestionType = e.target.getAttribute('data-suggestion-type');
            let endpointUrl = '';
            if (suggestionType === 'trending') {
                endpointUrl = '/Movies/TrendingReshuffle';
            } else if (suggestionType === 'cast') {
                endpointUrl = '/Movies/CastReshuffle';
            }
            if (endpointUrl) {
                const originalHTML = e.target.innerHTML;
                e.target.disabled = true;
                e.target.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Reshuffling...';

                fetch(endpointUrl, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                    timeout: 10000 // 10 seconds timeout
                })
                .then(response => {
                    if (!response.ok) throw new Error(`HTTP ${response.status}`);
                    return response.json();
                })
                .then(data => {
                    if (data.success && data.html) {
                        const container = document.querySelector('.row.row-cols-1.row-cols-sm-2.row-cols-md-3.g-4.justify-content-center');
                        if (container) {
                            container.innerHTML = data.html;
                            attachEventListeners(); // Importante: re-adjuntar listeners tras reemplazo
                        } else {
                            throw new Error('Container not found');
                        }
                    } else {
                        throw new Error(data.error || 'Invalid response');
                    }
                    e.target.disabled = false;
                    e.target.innerHTML = originalHTML;
                })
                .catch(error => {
                    console.error('Reshuffle error:', error);
                    alert('Failed to reshuffle: ' + error.message);
                    e.target.disabled = false;
                    e.target.innerHTML = originalHTML;
                });
            }
        }
    });

    function attachEventListeners() {
        document.querySelectorAll('.blacklist-form, .wishlist-form').forEach(form => {
            const newForm = form.cloneNode(true);
            form.parentNode.replaceChild(newForm, form);
            if (newForm.classList.contains('blacklist-form')) {
                newForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    const btn = newForm.querySelector('.blacklist-btn');
                    btn.disabled = true;
                    const card = newForm.closest('.movie-suggestion-card');
                    fetch(newForm.action, {
                        method: 'POST',
                        body: new FormData(newForm),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        credentials: 'same-origin'
                    })
                    .then(response => {
                        if (!response.ok) throw new Error('Blacklist failed');
                        card.style.transition = 'opacity 0.4s, transform 0.4s';
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.95) translateY(-20px)';
                        setTimeout(() => card.remove(), 400);
                    })
                    .catch(() => {
                        btn.disabled = false;
                        alert('Could not add to blacklist. Please try again.');
                    });
                });
            } else if (newForm.classList.contains('wishlist-form')) {
                newForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    const btn = newForm.querySelector('.wishlist-btn');
                    btn.disabled = true;
                    btn.textContent = 'Adding...';
                    fetch(newForm.action, {
                        method: 'POST',
                        body: new FormData(newForm),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        credentials: 'same-origin'
                    })
                    .then(response => {
                        if (!response.ok) throw new Error('Wishlist failed');
                        btn.textContent = 'Added ✓';
                        btn.classList.remove('btn-soft-primary');
                        btn.classList.add('btn-success');
                        btn.disabled = true;
                        const card = newForm.closest('.movie-suggestion-card');
                        if (card) {
                            const blacklistBtn = card.querySelector('.blacklist-btn');
                            if (blacklistBtn) {
                                blacklistBtn.disabled = true;
                                blacklistBtn.classList.remove('btn-soft-danger');
                                blacklistBtn.classList.add('btn-secondary');
                                blacklistBtn.textContent = 'Unavailable';
                            }
                            const blacklistForm = card.querySelector('.blacklist-form');
                            if (blacklistForm) {
                                blacklistForm.style.pointerEvents = 'none';
                                blacklistForm.style.opacity = '0.5';
                            }
                        }
                    })
                    .catch(() => {
                        btn.disabled = false;
                        btn.textContent = 'Add to Wishlist';
                        alert('Could not add to wishlist. Please try again.');
                    });
                });
            }
        });
    }
</script>
}