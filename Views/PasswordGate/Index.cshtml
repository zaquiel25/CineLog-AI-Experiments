@{
    ViewData["Title"] = "CineLog - Private Testing";
    Layout = null; // No layout for password gate
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .password-gate-container {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            max-width: 400px;
            width: 100%;
            text-align: center;
        }
        .logo {
            color: #f4d03f;
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .subtitle {
            color: #7f8c8d;
            margin-bottom: 30px;
        }
        .form-control:focus {
            border-color: #f4d03f;
            box-shadow: 0 0 0 0.2rem rgba(244, 208, 63, 0.25);
        }
        .btn-primary {
            background-color: #f4d03f;
            border-color: #f4d03f;
            color: #2c3e50;
            font-weight: 600;
            padding: 12px 30px;
        }
        .btn-primary:hover {
            background-color: #f1c40f;
            border-color: #f1c40f;
            color: #2c3e50;
        }
        .alert {
            border-radius: 8px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="password-gate-container">
        <div class="logo">🎬 CineLog</div>
        <p class="subtitle">Private Testing Access</p>
        
        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @ViewBag.ErrorMessage
            </div>
        }
        
        <form method="post" asp-antiforgery="true">
            <div class="mb-3">
                <input type="password" 
                       class="form-control" 
                       name="password" 
                       placeholder="Enter password to access CineLog" 
                       required 
                       autofocus />
            </div>
            
            <div class="form-check mb-3 text-start">
                <input class="form-check-input" type="checkbox" name="rememberMe" id="rememberMe" />
                <label class="form-check-label" for="rememberMe">
                    Remember me for 7 days
                </label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-lg w-100">
                Access CineLog
            </button>
        </form>
        
        <p class="text-muted mt-4 small">
            This site is currently in private testing.<br>
            Contact the administrator if you need access.
        </p>
    </div>
</body>
</html>