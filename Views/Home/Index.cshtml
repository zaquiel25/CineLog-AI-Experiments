@{
    ViewData["Title"] = "Home - FrameRoute";
}


<h1>FrameRoute</h1>
<p>Your journey in film: Watch, Log, Discover.</p>
<div style="margin-top:2.2rem; display:flex; justify-content:center; flex-wrap:wrap; gap:0.5rem;">
    <a asp-controller="Movies" asp-action="Add" class="hero-btn hero-btn-gold">Add New Movie</a>
    <a asp-controller="Movies" asp-action="Suggest" class="hero-btn hero-btn-secondary">Explore Suggestions</a>
</div>
<div class="how-it-works-section">
    <div class="process-steps">
        <div class="step">
            <div class="step-icon">
                <i class="bi bi-journal-plus"></i>
            </div>
            <span class="step-text">Log what you watch</span>
        </div>
        <div class="step-arrow">
            <i class="bi bi-arrow-right"></i>
        </div>
        <div class="step">
            <div class="step-icon">
                <i class="bi bi-person-gear"></i>
            </div>
            <span class="step-text">Build your profile</span>
        </div>
        <div class="step-arrow">
            <i class="bi bi-arrow-right"></i>
        </div>
        <div class="step">
            <div class="step-icon">
                <i class="bi bi-stars"></i>
            </div>
            <span class="step-text">Discover perfect matches</span>
        </div>
    </div>
</div>
