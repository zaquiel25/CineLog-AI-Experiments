<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineLog</title> @* Corrected with a hyphen *@
    <link rel="stylesheet" href="~/css/bootstrap.min.css" /> @* <<< NOW POINTING TO YOUR NEW THEME IN wwwroot/css/ *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ezequiel_Movies.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            @* CHANGED: navbar-dark bg-primary *@
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-film me-2"></i>CineLog @* Optional: Icon for brand *@
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Movies" asp-action="List">
                                @* text-dark removed, navbar-dark handles text color *@
                                <i class="bi bi-collection-play me-1"></i>My Movies
                            </a>
                        </li>
                        @* VVVV NEW NAV LINK FOR MOVIE SUGGESTIONS VVVV *@
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Movies" asp-action="Suggest">
                                @* text-dark removed *@
                                <i class="bi bi-lightbulb me-1"></i>Movie Suggestions
                            </a>
                        </li>
                        @* ^^^^ END OF NEW NAV LINK ^^^^ *@
                    </ul>
                    @* You might add user/login related items on the right-hand side in the future:
                <ul class="navbar-nav">
                    <li class="nav-item">User Info / Logout</li>
                </ul>
                    *@
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-light bg-dark mt-auto py-3">
        @* CHANGED: classes for color, added padding *@
        <div class="container text-center">
            @* ADDED: text-center to center content *@
            &copy; @DateTime.Now.Year - CineLog - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="link-light">Privacy</a> @* MODIFIED: link class for better visibility *@
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

