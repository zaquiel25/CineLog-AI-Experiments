@model Ezequiel_Movies.Models.TmdbApi.TmdbMovieBrief

@{
    var tmdbImageBaseUrl = "https://image.tmdb.org/t/p/w342";
}

<div class="col">
    <div class="card h-100 shadow-sm movie-suggestion-card" id="movie-card-@Model.Id">
        @* The link is now wrapped around the image *@
        <a asp-controller="Movies" asp-action="Preview" asp-route-tmdbId="@Model.Id">
            @if (!string.IsNullOrEmpty(Model.PosterPath))
            {
                <img src="@(tmdbImageBaseUrl + Model.PosterPath)" class="card-img-top" alt="@Model.Title Poster" style="height: 300px; width: 100%; object-fit: contain;">
            }
            else
            {
                <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height: 300px; font-size:0.8rem; color: #6c757d;">
                    <span>No Poster Available</span>
                </div>
            }
        </a>
        <div class="card-body d-flex flex-column">
            <h6 class="card-title mb-1" style="font-size: 0.85rem; font-weight: 600;">
                <a asp-action="Preview" asp-controller="Movies" asp-route-tmdbId="@Model.Id" class="link-as-text">
                    @Model.Title
                </a>
            </h6>
            @* Badge 'Watched' exactamente como en My Movies (pequeño, pill, bg-warning, inline) *@
            @if (Model.IsWatched == true)
            {
                <li class="mt-1 list-unstyled"><span class="badge rounded-pill bg-warning">Watched</span></li>
            }
            <p class="card-text mb-2" style="margin-top: 2px;">
                <small class="text-muted">@(!string.IsNullOrEmpty(Model.ReleaseDate) && Model.ReleaseDate.Length >= 4 ? Model.ReleaseDate.Substring(0, 4) : "")</small>
            </p>

            <div class="mt-auto">
                <div class="row g-1 mb-1">
                    <div class="col-6">
                        <button class="btn btn-soft-primary btn-sm w-100">Add to Wishlist</button>
                    </div>
                    <div class="col-6">
                        @* Only show blacklist form if not in wishlist (mutual exclusion) *@
                        @if (!(Model.IsInWishlist ?? false))
                        {
                            <form class="blacklist-form" data-tmdbid="@Model.Id" method="post" action="/Movies/AddToBlacklist">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tmdbId" value="@Model.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <button type="submit" class="btn btn-soft-danger btn-sm w-100 blacklist-btn">Add to Blacklist</button>
                            </form>
                        }
                    </div>
                </div>
                <a asp-controller="Movies" asp-action="Add" asp-route-tmdbId="@Model.Id" class="btn btn-soft-success btn-sm w-100">
                    <i class="bi bi-plus-circle me-1"></i> Add to My Movies
                </a>
            </div>
        </div>
    </div>
</div>