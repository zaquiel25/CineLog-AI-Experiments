# Specifies intentionally untracked files that Git should ignore.
# Each line is a pattern.
# More info: https://git-scm.com/docs/gitignore

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/

# Publish outputs and deployment artifacts
publish/
*.zip

# Azure logs and deployment artifacts (downloaded for troubleshooting)
LogFiles/
deployments/
current-logs.zip
deployment-*.zip

# Visual Studio Code files
.vscode/

# Rider files
.idea/

# Secrets (if you're using appsettings.Development.json for sensitive data, consider ignoring it too,
# but ensure production configurations are handled differently, e.g., environment variables or Azure Key Vault)
# For example, if your connection string or API keys are in appsettings.Development.json
# AND you don't want to commit them (even to a private repo, though less critical for private):
# appsettings.Development.json

# Environment variables file from .NET User Secrets (if you use them)
secrets.json

# NuGet packages
packages/
*.nupkg

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Node.js dependencies (if you were using npm/yarn directly)
node_modules/
dist/
dist-server/

# Dotenv environment variable files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# macOS cache files
.DS_Store

# EF Core Migrations - typically you DO want to commit these, but if you have a strategy
# to always generate them in CI/CD or for different DBs, you might ignore them.
# For now, let's assume you DO commit your Migrations folder.
# Migrations/

# SQLite database file (if you were using SQLite and don't want to commit the .db file)
# *.db
# *.db-shm
# *.db-wal

.vs/
.fake

# Session secretary context notes (local development context only)
SESSION_NOTES.md

# Internal development planning docs (local reference only)
production-deployment-checklist.md
MOBILE_STRATEGY.md
DESIGN_HUMANIZATION_ROADMAP.md

# Claude Code session transcripts and conversation exports (local AI development context only)
2025-*.txt
*-claude-conversation*.txt
*-session-transcript*.txt
*-ai-conversation*.txt

# Specific Claude conversation files
2025-08-07-can-u-read-our-project-and-your-instructions.txt
2025-07-30-i-need-you-to-review-please-the-layout-and-design.txt
2025-08-07-this-session-is-being-continued-from-a-previous-co.txt
2025-07-29-this-session-is-being-continued-from-a-previous-co.txt


# Azure deployment files and local settings
.claude/settings.local.json

# Codex AI tool configuration (personal development environment)
.codex/

# SQLite database files (if using SQLite for development)
*.db
*.db-*
EzequielMovies.db