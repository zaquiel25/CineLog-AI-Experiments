{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:cinelog-sql-server.database.windows.net,1433;Database=CineLog_Production;User ID=cinelogadmin;Password={DatabasePassword};Encrypt=True;TrustServerCertificate=False;Connection Timeout=60"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "VaultUri": "https://[YOUR-KEYVAULT].vault.azure.net/"
  },
  "TMDB": {
    "AccessToken": "{TMDB--AccessToken}"
  }
}